# ── LLM Configuration ─────────────────────────────────────────────────────────
# Choose one provider: openai | anthropic | gemini | glm | kimi | qwen | ollama
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
LLM_MAX_TOKENS=800

# OpenAI (also works as base for custom endpoints)
OPENAI_API_KEY=sk-your-key-here
OPENAI_BASE_URL=https://api.openai.com/v1

# Anthropic Claude
# ANTHROPIC_API_KEY=

# Google Gemini
# GEMINI_API_KEY=

# Zhipu GLM
# GLM_API_KEY=

# Moonshot Kimi
# KIMI_API_KEY=

# Alibaba Qwen
# QWEN_API_KEY=

# Ollama (local)
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3

# ── ArXiv Configuration ────────────────────────────────────────────────────────
ARXIV_CATEGORIES=cs.AI,cs.LG,cs.CV
ARXIV_MAX_RESULTS=200
ARXIV_HOURS=24
PAPERS_PER_DAY=10

# ── Filter Keywords (comma-separated, empty = no filter) ──────────────────────
KEYWORDS=

# ── Storage ────────────────────────────────────────────────────────────────────
SUMMARIES_DIR=./data/summaries
DATABASE_URL=sqlite+aiosqlite:///./data/arxiv_agent.db
