{
    "database_url": "sqlite+aiosqlite:///./data/arxiv_agent.db",
    "arxiv_categories": [
        "cs.AI",
        "cs.LG",
        "cs.CV"
    ],
    "arxiv_max_results": 100,
    "arxiv_days": 7,
    "papers_per_day": 10,
    "llm_provider": "gemini",
    "llm_max_tokens": 2000,
    "llm_concurrency": 1,
    "llm_wait_seconds": 50,
    "providers": {
        "openai": {
            "model": "gpt-5.4-mini",
            "api_key": "ENV_MAPPED",
            "base_url": "https://api.openai.com/v1",
            "available_models": [
                "gpt-5.4",
                "gpt-5.4-mini",
                "gpt-5.3-instant"
            ]
        },
        "anthropic": {
            "model": "claude-4.6-sonnet",
            "api_key": "ENV_MAPPED",
            "base_url": "none",
            "available_models": [
                "claude-4.6-sonnet",
                "claude-4.6-opus"
            ]
        },
        "gemini": {
            "model": "gemma-3-27b-it",
            "api_key": "ENV_MAPPED",
            "base_url": "none",
            "available_models": [
                "gemini-3.1-flash-lite",
                "gemini-3.1-flash-live",
                "gemini-3.1-pro",
                "gemma-3-27b-it"
            ]
        },
        "glm": {
            "model": "glm-5.1",
            "api_key": "ENV_MAPPED",
            "base_url": "https://open.bigmodel.cn/api/paas/v4",
            "available_models": [
                "glm-5.1",
                "glm-5",
                "glm-5-turbo"
            ]
        },
        "kimi": {
            "model": "moonshot-k2.5",
            "api_key": "ENV_MAPPED",
            "base_url": "https://api.moonshot.cn/v1",
            "available_models": [
                "moonshot-k2.5",
                "moonshot-k2-thinking"
            ]
        },
        "qwen": {
            "model": "qwen3.5-plus",
            "api_key": "ENV_MAPPED",
            "base_url": "https://dashscope.aliyuncs.com/compatible-mode/v1",
            "available_models": [
                "qwen3.5-plus",
                "qwen3-max-thinking",
                "qwen3.5-max"
            ]
        },
        "ollama": {
            "model": "llama3",
            "api_key": "ENV_MAPPED",
            "base_url": "http://localhost:11434/v1",
            "available_models": [
                "llama3",
                "mistral",
                "qwen2.5",
                "deepseek-r1"
            ]
        }
    },
    "keywords": [],
    "summaries_dir": "./data/summaries",
    "auto_fetch_cron": "30 7 * * 1",
    "auto_fetch_enabled": true
}